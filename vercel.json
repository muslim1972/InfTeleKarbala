{
  "github": {
    "silent": false,
    "deploymentEnabled": {
      "main": false,
      "stable-info-karbala": true
    }
  },
  "alias": "inf-tele-karbala.vercel.app",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; worker-src 'self' blob: https:; frame-src 'self' https:; manifest-src 'self';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/OneSignalSDKWorker.js",
      "destination": "/OneSignalSDKWorker.js"
    },
    {
      "source": "/OneSignalSDKUpdaterWorker.js",
      "destination": "/OneSignalSDKUpdaterWorker.js"
    },
    {
      "source": "/((?!api/|OneSignalSDKWorker|OneSignalSDKUpdaterWorker).*)",
      "destination": "/index.html"
    }
  ]
}